        MC_esc_tog0_all: MC_esc_tog0_all {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp ESC &tog_off 1 &tog_off 3 &tog_off 4>;
            label = "ESC + Toggle all layers off";
        };

        MC_ldrkey: MC_ldrkey {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&to 0 &kp F13>;
            label = "Switch to Alpha before launching Leader Key";
        };

        // activate a modifier and a layer at the same time

        Fake_LayerMod: new_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&KT_ON LGUI &mo 4>,
                <&macro_pause_for_release>,
                <&macro_release>,
                <&KT_OFF LGUI>;

            label = "NEW_MACRO";
        };

        MC_los_wmsl: MC_los_wmsl {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_tap>, <&sl 5 &sl 3>;

            label = "One-shot L3 / L5 (tog_on L3)";
        };

        MC_L3_lh1: MC_L3_lh1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&tog_off 3 &tog_on 1>,
                <&macro_pause_for_release>,
                <&tog_off 1 &tog_on 3>;

            label = "While held, disable L3 and and activate L1";
        };

        gap2chm: MC_gapOFF_hrmON {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_tap>, <&tog_off 2 &tog_on 5>;
        };

