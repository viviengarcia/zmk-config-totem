            label = "ov_FUNC_3";
            bindings = <&kp N3>, <&kp F3>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        ov_func_4: ov_func_4 {
            compatible = "zmk,behavior-mod-morph";
            label = "ov_FUNC_4";
            bindings = <&kp N4>, <&kp F4>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        ov_func_5: ov_func_5 {
            compatible = "zmk,behavior-mod-morph";
            label = "ov_FUNC_5";
            bindings = <&kp N5>, <&kp F5>;

            #binding-cells = <0>;
