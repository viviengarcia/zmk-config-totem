    combos {
        compatible = "zmk,combos";

        // launch raycast prompt
        // CB_rcast {
        //     bindings = <&kp F15>;
        //     key-positions = <5 15>;
        //     layers = <0 1 3 4>;
        // };
        // launch leaderkey prompt
        // CB_ldrk {
        //     bindings = <&kp F13>;
        //     key-positions = <4 14>;
        //     layers = <0 1 3 4>;
        // };
        // flip between alpha and app layers

        CB_gap2chm {
            bindings = <&gap2chm>;
            key-positions = <2 34>;
            layers = <2>;
        };

        CB_chm2gap {
            bindings = <&chm2gap>;
            key-positions = <2 34>;
            layers = <0>;
        };

        CB_lh_dvce {
            bindings = <&mo 6>;
            key-positions = <35 7>;
            layers = <0 1 3>;
        };

        CB_los_play {
            bindings = <&sl 4>;
            key-positions = <26 36>;
            layers = <0 1 2 3>;
        };

        CB_tog_play {
            bindings = <&tog 4>;
            key-positions = <26 36>;
            layers = <4>;
        };

        CB_btclear {
            bindings = <&bt BT_CLR>;
            key-positions = <37 32>;
            layers = <0>;
        };

        // brackets, etc.

        CB_LParenthesis {
            bindings = <&kp LPAR>;
            key-positions = <1 2>;
            layers = <0 1 3>;
        };

        CB_RParenthesis {
            bindings = <&kp RPAR>;
            key-positions = <2 3>;
            layers = <0 1 3>;
        };

        CB_LBracket {
            bindings = <&kp LBKT>;
            key-positions = <16 17>;
            layers = <0 1 3>;
        };

        CB_RBracket {
            bindings = <&kp RBKT>;
            key-positions = <17 18>;
            layers = <0 1 3>;
        };

        CB_LBrace {
            bindings = <&kp LBRC>;
            key-positions = <11 12>;
            layers = <0 1 3>;
        };

        CB_RBrace {
            bindings = <&kp RBRC>;
            key-positions = <12 13>;
            layers = <0 1 3>;
        };

        CB_LAngleBracket {
            bindings = <&kp LT>;
            key-positions = <6 7>;
            layers = <1 3>;
        };

        CB_RAngleBracket {
            bindings = <&kp GT>;
            key-positions = <7 8>;
            layers = <1 3>;
        };

        CB_GuillmtOpen {
            bindings = <&MC_guillmt_opn>;
            key-positions = <6 7>;
            layers = <0>;
        };

        CB_GuillmtClose {
            bindings = <&MC_guillmt_cls>;
            key-positions = <7 8>;
            layers = <0>;
        };

        CB_ae {
            bindings = <&MC_ae>;
            key-positions = <11 16>;
            layers = <0>;
        };

        CB_oe {
            bindings = <&MC_oe>;
            key-positions = <16 18>;
            layers = <0>;
        };

        // apply OV_func(s) only on specified layers

        CB_ov_f1 {
            bindings = <&OV_func_1>;
            key-positions = <0 0>;
            layers = <2>;
        };

        CB_ov_f2 {
            bindings = <&OV_func_2>;
            key-positions = <1 1>;
            layers = <2>;
        };

        CB_ov_f3 {
            bindings = <&OV_func_3>;
            key-positions = <2 2>;
            layers = <2>;
        };

        CB_ov_f4 {
            bindings = <&OV_func_4>;
            key-positions = <3 3>;
            layers = <2>;
        };

        CB_ov_f5 {
            bindings = <&OV_func_5>;
            key-positions = <4 4>;
            layers = <2>;
        };

        CB_ov_f6 {
            bindings = <&OV_func_6>;
            key-positions = <5 5>;
            layers = <2>;
        };

        CB_ov_f7 {
            bindings = <&OV_func_7>;
            key-positions = <6 6>;
            layers = <2>;
        };

        CB_ov_f8 {
            bindings = <&OV_func_8>;
            key-positions = <7 7>;
            layers = <2>;
        };

        CB_ov_f9 {
            bindings = <&OV_func_9>;
            key-positions = <8 8>;
            layers = <2>;
        };

        CB_ov_f0 {
            bindings = <&OV_func_0>;
            key-positions = <9 9>;
            layers = <2>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // L0
        chm {
            display-name = "Chars - Main";
            bindings = <
        &kp G   &kp Q   &kp Y               &kp W               &kp J                           &kp B       &kp H               &kp M               &MC_agrave  &kp F
        &kp S   &kp A   &HT_hrm_StL SL N    &HT_hrm_StL ML U    &TD_com_sqt                     &TD_dot_min &HT_hrm_StR ML E    &HT_hrm_StR SL T    &kp O       &kp L
&kp ESC &kp Z   &kp X   &HT_hrm_StL CL C    &HT_hrm_StL AL V    &kp TAB                         &tog 5      &HT_hrm_StR AL I    &HT_hrm_StR CL D    &kp P       &kp K  &kp ENTER
                                            &kp ML              &sl 1       &kp SPACE   &kp R   &sl 3       &TD_lnchr
            >;
        };

        // L1
        chx {
       	   	display-name = "Chars - eXtended";
            bindings = <
                  &kp PIPE   &kp AT     &kp HASH            &kp DOLLAR              &kp AMPS                                &kp EXCLAMATION &kp QUESTION            &MC_ocirc           &MC_ccedil  &MC_euro
                  &kp MINUS  &kp PLUS   &HT_hrm_StL SL STAR &HT_hrm_StL ML SLASH    &kp DOUBLE_QUOTES                       &kp UNDERSCORE  &hrm_StR_ugrave ML 0    &hrm_StR_ucirc SL 0 &MC_utrema  &kp PERCENT
&MC_esc_tog0_all  &kp TILDE  &kp GRAVE  &HT_hrm_StL CL BSLH &HT_hrm_StL AL EQUAL    &trans                                  &trans          &hrm_StR_egrave AL 0    &hrm_StR_ecirc CL 0 &MC_etrema  &kp CARET   &trans
                                                            &trans                  &tog 1              &trans  &MC_eacute  &trans          &trans
            >;
        };

        // L2
        gap {
       	   	display-name = "Games & Apps";
            bindings = <
                &kp N1  &kp N2  &kp N3  &kp N4  &kp N5                          &kp G       &kp O   &kp B   &kp K   &kp RBKT
                &kp TAB &trans  &kp N   &kp U   &kp COMMA                       &kp PERIOD  &kp T   &kp M   &kp L   &kp LBKT
        &kp SL  &kp CL  &trans  &kp C   &kp V   &kp Y                           &kp ENTER   &kp E   &kp I   &kp F   &kp F5  &kp F9
                                &trans  &kp AL  &kp SPACE   &kp PLUS    &kp R   &kp MINUS
            >;
        };

        // L3
        wms {
       	   	display-name = "WM / Select";
            bindings = <
                    &none   &kp KP_N7   &kp KP_N8   &kp KP_N9    &kp KP_N0                      &trans  &kp MINUS                   &kp EQUAL           &none       &none
                    &none   &kp KP_N4   &kp KP_N5   &kp KP_N6    &kp PERIOD                     &trans  &HT_hrm_StR ML BACKSPACE    &HT_hrm_StR SL UP   &kp DEL     &none
&MC_esc_tog0_all    &none   &kp KP_N1   &kp KP_N2   &kp KP_N3    &kp LS(LGUI)                   &trans  &HT_hrm_StR AL LEFT         &HT_hrm_StR CL DOWN &kp RIGHT   &none   &none
                                                    &trans       &MC_L3_lh1     &trans  &trans  &tog 3  &trans
            >;
        };

        // L4
        mpl {
       	   	display-name = "Media Player";
            bindings = <
                    &none   &trans  &trans  &trans      &trans                              &kp C_VOL_UP    &kp COMMA  &kp LA(RIGHT)  &kp DOT    &kp LS(GT)
                    &none   &trans  &trans  &trans      &none                               &kp C_VOL_DN    &kp LEFT   &kp C_PLAY     &kp RIGHT  &kp LS(LT)
&MC_esc_tog0_all    &none   &trans  &trans  &trans      &none                               &trans          &kp J      &kp LA(LEFT)   &kp L      &none       &none
                                            &kp SPACE   &kp SPACE   &kp SPACE   &kp SPACE   &kp SPACE       &trans
            >;
        };

        // L5
        hrm {
       	   	display-name = "Homerow Mods";
            bindings = <
        &trans  &trans  &trans          &trans          &trans                  &trans  &trans      &trans       &trans  &trans
        &trans  &trans  &htr LSHFT 0    &htr LGUI 0     &trans                  &trans  &htr LGUI 0 &htr LSHFT 0 &trans  &trans
&trans  &trans  &trans  &htr LCTRL 0    &htr LALT 0     &trans                  &trans  &htr LALT 0 &htr LCTRL 0 &trans  &trans  &trans
                                        &trans          &trans  &trans  &trans  &trans  &trans
            >;
        };

        // L6
        dvc {
       	   	display-name = "Device";
            bindings = <
                    &bt BT_SEL 0    &bt BT_SEL 1    &bt BT_SEL 2    &bt BT_SEL 3    &bt BT_SEL 4                    &trans  &trans  &trans  &trans  &trans
                    &bt BT_PRV      &bt BT_NXT      &none           &none           &none                           &trans  &trans  &trans  &trans  &trans
&MC_esc_tog0_all    &none           &none           &none           &none           &trans                          &trans  &trans  &trans  &trans  &trans  &trans
                                                                    &trans          &trans          &trans  &trans  &trans  &trans
            >;
        };

        //         tpl {
        //             bindings = <
        //         &trans  &trans  &trans  &trans  &trans                   &trans  &trans  &trans  &trans  &trans
        //         &trans  &trans  &trans  &trans  &trans                   &trans  &trans  &trans  &trans  &trans
        // &trans  &trans  &trans  &trans  &trans  &trans                   &trans  &trans  &trans  &trans  &trans  &trans
        //                                 &trans  &trans  &trans  &trans   &trans  &trans
        //             >;
        //         };
    };

    conditional_layers {
    	compatible = "zmk,conditional-layers";
        // boot_layers {
        //    	if-layers = <0>;
        //     then-layer = <5>;
        // };
    };
};
