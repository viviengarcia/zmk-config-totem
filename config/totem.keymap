        tog_on: toggle_layer_on_only {
            compatible = "zmk,behavior-toggle-layer";
            #binding-cells = <1>;
            display-name = "Toggle Layer On";
            toggle-mode = "on";
            locking;
        };

        tog_off: toggle_layer_off_only {
            compatible = "zmk,behavior-toggle-layer";
            #binding-cells = <1>;
            display-name = "Toggle Layer Off";
            toggle-mode = "off";
            locking;
        };

        // t: [,] td: [;]

        TD_semicomma: TD_semicomma {
            compatible = "zmk,behavior-tap-dance";
            label = "Double-tap [COMMA] -> [SEMICOLON]";
            #binding-cells = <0>;
            bindings = <&kp COMMA>, <&kp SEMI>;

            tapping-term-ms = <200>;
        };

        // t: [.] td: [:]

        TD_dotcolon: TD_dotcolon {
            compatible = "zmk,behavior-tap-dance";
            label = "Double-tap [PERIOD] -> [COLON]";
            #binding-cells = <0>;
            bindings = <&kp DOT>, <&kp LS(SEMI)>;

            tapping-term-ms = <200>;
        };

        // t: [x] td: [z]
        // TD_x_z: TD_x_z {
        //     compatible = "zmk,behavior-tap-dance";
        //     label = "Double-tap [X] -> [Z]";
        //     #binding-cells = <0>;
        //     bindings = <&kp X>, <&kp Z>;
        //     tapping-term-ms = <150>;
        // };
        // t: [.] td: [-]

        TD_dot_min: TD_dot_min {
            compatible = "zmk,behavior-tap-dance";
            label = "Double-tap [PERIOD] -> [MINUS]";
            #binding-cells = <0>;
            bindings = <&kp PERIOD>, <&kp MINUS>;

            tapping-term-ms = <200>;
        };

        // t: [,] td: [']

        TD_com_sqt: TD_com_sqt {
            compatible = "zmk,behavior-tap-dance";
            label = "Double-tap [COMMA] -> [SINGLE_QUOTE]";
            #binding-cells = <0>;
            bindings = <&kp COMMA>, <&kp SQT>;

            tapping-term-ms = <200>;
        };

        // t: [-] dt: [?]

        TD_min_qsm: TD_min_qsm {
            compatible = "zmk,behavior-tap-dance";
            label = "Double-tap [MINUS] -> [SINGLE_QUOTE]";
            #binding-cells = <0>;
            bindings = <&kp MINUS>, <&kp QUESTION>;

            tapping-term-ms = <200>;
        };

        // t: [;] dt: ["]

        TD_scln_dsqt: TD_scln_dsqt {
            compatible = "zmk,behavior-tap-dance";
            label = "Double-tap [SEMICOLON] -> [DOUBLE_QUOTES]";
            #binding-cells = <0>;
            bindings = <&kp SEMI>, <&kp DOUBLE_QUOTES>;

            tapping-term-ms = <200>;
        };

        // t: [_] td: [!]

        TD_undr_excl: TD_undr_excl {
            compatible = "zmk,behavior-tap-dance";
            label = "Double-tap [UNDERSCORE] -> [EXCLAMATION_MARK]";
            #binding-cells = <0>;
            bindings = <&kp UNDER>, <&kp EXCL>;

            tapping-term-ms = <200>;
