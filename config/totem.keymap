        // t: [leaderkey] td: [raycast]

        lnch: td_leadrkey_raycast {
            compatible = "zmk,behavior-tap-dance";
            label = "t->Raycast, td->LeaderKey";
            #binding-cells = <0>;
            bindings = <&kp F13>, <&kp F15>;

            tapping-term-ms = <200>;
        };

        // t: [lsft] td: [capsword]

        sscw: td_stickyLShift_capsWord {
            compatible = "zmk,behavior-tap-dance";
            label = "t->stLSft, td->capsWord";
            #binding-cells = <0>;
            bindings = <&sk LSHFT>, <&caps_word>;

            tapping-term-ms = <200>;
        };

        // // LS[␣] -> […]

        // ov_spcElipsis: ov_spcElipsis {
        //     compatible = "zmk,behavior-mod-morph";
        //     label = "Shifted [␣] -> […]";
        //     bindings = <&kp SPACE>, <&kp LA(SEMICOLON)>;

        //     #binding-cells = <0>;
        //     mods = <(MOD_LSFT|MOD_RSFT)>;
        // };

        // LS[,] -> [;]
        cmsc: ov_comma_semicolon {
            compatible = "zmk,behavior-mod-morph";
            bindings = <&cmsq>, <&kp SEMICOLON>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        // LS[.] -> [:]
        prcl: ov_period_colon {
            compatible = "zmk,behavior-mod-morph";
            bindings = <&dtmn>, <&kp COLON>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT|MOD_RSFT)>;
        };

        // LS[0-9] -> f-keys

        ov_func_0: ov_func_0 {
            compatible = "zmk,behavior-mod-morph";
            label = "ov_FUNC_10";
            bindings = <&kp N0>, <&kp F10>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        ov_func_1: ov_func_1 {
            compatible = "zmk,behavior-mod-morph";
            label = "ov_FUNC_1";
            bindings = <&kp N1>, <&kp F1>;

