        //     tapping-term-ms = <150>;
        // };

        // t: [,] td: [']
        cmsq: td_comma_singlequote {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            bindings = <&kp COMMA>, <&kp SQT>;

            tapping-term-ms = <200>;
        };

        // t: [.] td: [-]
        prmn: td_period_minus {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            bindings = <&kp PERIOD>, <&kp MINUS>;

            tapping-term-ms = <200>;
        };

        // // t: [-] dt: [?]

        // td_min_qsm: td_min_qsm {
        //     compatible = "zmk,behavior-tap-dance";
        //     label = "Double-tap [MINUS] -> [SINGLE_QUOTE]";
