    behaviors {
        // hold-tap only for layers
        // to activate a layer while held OR to switch to it
        // depending on the gesture

        HT_lh_lto: HT_lh_lto {
            compatible = "zmk,behavior-hold-tap";
            label = "HT_LH_LTO";
            bindings = <&mo>, <&sl>;

            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <180>;
        };

        HT_lh_Flos: HT_lh_Flos {
            compatible = "zmk,behavior-hold-tap";
            label = "h->Mo(x), t->fake one-shot L3";
            bindings = <&mo>, <&MC_los_wmsl>;

            #binding-cells = <2>;
            flavor = "hold-preferred";
            tapping-term-ms = <180>;
        };

        // hold: Mo(), tap: OSL()
        // HT_hl_ol: HT_hl_ol {
        //     compatible = "zmk,behavior-hold-tap";
        //     label = "HT_HL_OL";
        //     bindings = <&MC_lh0_alpha>, <&KP_lf0>;
        //     #binding-cells = <2>;
        //     flavor = "balanced";
        //     tapping-term-ms = <280>;
        //     quick-tap-ms = <175>;
        //     require-prior-idle-ms = <150>;
        // };
        // hold-tap tpl for thumbs
        // - thumbs strong+ agility-
        // - hold gesture combines with keys from both keeb halves

        THT_Tbs: THT_Tbs {
            compatible = "zmk,behavior-hold-tap";
            label = "[tpl] Thumbs Hold-Tap (Basic Behavior)";
            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <280>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <175>;
            hold-trigger-on-release;
            bindings = <&kp>, <&sl>;
        };

        // hold-tap tpl for homerow mods

        THT_HRM: THT_HRM {
            compatible = "zmk,behavior-hold-tap";
            label = "THT_HRM";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <280>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <175>;
            hold-trigger-on-release;
        };

        htr: HT__hold_zmk_behavior__tap_transparent {
            compatible = "zmk,behavior-hold-tap";
            bindings = <&kp>, <&trans>;

            #binding-cells = <2>;
            flavor = "balanced";
            tapping-term-ms = <280>;
            quick-tap-ms = <200>;
            require-prior-idle-ms = <175>;
            hold-trigger-on-release;
        };

        // mod-morph tpl for alternate shift output

        TOV_LSFT: TOV_LSFT {
            compatible = "zmk,behavior-mod-morph";
            label = "TOV_LSFT";
            bindings = <&kp COMMA>, <&kp SQT>;

            #binding-cells = <0>;
