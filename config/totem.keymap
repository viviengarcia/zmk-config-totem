#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

// #define MOF_TOG(layer) &mof_tog layer layer
// #define MOFMO_TOG(layer) &mofmo_tog layer layer

// Modifier keys - shortcuts for the layers bindings
#define   SL  LSHFT
#define   CL  LCTRL
#define   AL  LALT
#define   ML  LGUI

// SHORTS FORMS
//
// Signals
// kp: key press (alter default key output)
// kh: key held
//
// Motions
// td: tap-dance
// cb: combo
//
// Behaviors
// mc: macro
//   lm: layer-mod
// ov: mod-morph
// ht: hold-tap
//   mt: mod-tap
//   lt: layer-tap
//
// Actions
// pX: tap send X
// hX: hold send X
// toX: switch to layer X while disabling other non-defaults layers
// sX: sticky key/layer/mod X
// Xon: force X on
// Xoff: force X off
//
// Concepts
// thl: this layer
// hrm: homerow mods
// fs: finger strong
// fw: finger weak
//
//
// MACROS, BEHAVIORS & COMBOS TEMPLATES
// - name hints at either result > method

/ {
    macros {
        agrv: mc_a_grave {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings =
                <&macro_press>,
                <&kp LALT>,
                <&macro_tap>,
                <&kp U &kp PLUS &kp N0 &kp N0 &kp LS(E) &kp N0>,
                <&macro_release>,
                <&kp LALT>;

