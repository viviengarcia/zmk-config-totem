        // t: [leaderkey] td: [raycast]

        TD_lnchr: TD_lnchr {
            compatible = "zmk,behavior-tap-dance";
            label = "t->Raycast, td->LeaderKey";
            #binding-cells = <0>;
            bindings = <&kp F13>, <&kp F15>;

            tapping-term-ms = <200>;
        };

        // t: [lsft] td: [capsword]

        sLS_CW: TD_stickyLShift_capsWord {
            compatible = "zmk,behavior-tap-dance";
            label = "t->stLSft, td->capsWord";
            #binding-cells = <0>;
            bindings = <&sk LSHFT>, <&caps_word>;

            tapping-term-ms = <200>;
        };

        // LS[␣] -> […]

        OV_spcElipsis: OV_spcElipsis {
            compatible = "zmk,behavior-mod-morph";
